     "]"}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Chapter", " ", "3", " ", "function"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"eAniso", "[", 
     RowBox[{
      RowBox[{"alpha_", "?", "NumericQ"}], ",", 
      RowBox[{"beta_", "?", "NumericQ"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "aRad", ",", "bRad", ",", "ry", ",", "rz", ",", "rzT", ",", "ryT"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"aRad", "=", 
        RowBox[{"alpha", "*", "Degree"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"bRad", "=", 
        RowBox[{"beta", "*", "Degree"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Define", " ", "R", " ", "matrices"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"ry", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Cos", "[", "bRad", "]"}], ",", "0", ",", 
            RowBox[{"-", 
             RowBox[{"Sin", "[", "bRad", "]"}]}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "1", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Sin", "[", "bRad", "]"}], ",", "0", ",", 
            RowBox[{"Cos", "[", "bRad", "]"}]}], "}"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rz", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Cos", "[", "aRad", "]"}], ",", 
            RowBox[{"Sin", "[", "aRad", "]"}], ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"Sin", "[", "aRad", "]"}]}], ",", 
            RowBox[{"Cos", "[", "aRad", "]"}], ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Defining", " ", "transposes"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"rzT", "=", 
        RowBox[{"Transpose", "[", "rz", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ryT", "=", 
        RowBox[{"Transpose", "[", "ry", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Matrix", " ", "multiplication"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"ry", ".", "rz", ".", "eBiax", ".", "rzT", ".", "ryT"}]}]}], 
     "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
