   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "q", ",", "M", ",", "S", ",", "integrand", ",", "D", ",", "Dxx", ",", 
       "Dxy", ",", "Dyy", ",", "Dzz"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"q", "[", 
        RowBox[{"theta_", ",", "phi_"}], "]"}], ":=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Sin", "[", "theta", "]"}], " ", 
          RowBox[{"Cos", "[", "phi", "]"}]}], ",", 
         RowBox[{
          RowBox[{"Sin", "[", "theta", "]"}], " ", 
          RowBox[{"Sin", "[", "phi", "]"}]}], ",", 
         RowBox[{"Cos", "[", "theta", "]"}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"Numerator", ":", " ", 
        RowBox[{"invU", " ", ".", " ", "q", " ", ".", " ", 
         SuperscriptBox["q", "T"], " ", ".", " ", "invU"}]}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"M", "[", 
