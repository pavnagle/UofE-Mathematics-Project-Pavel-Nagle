Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Parameters"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"epsA", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"10", "+", 
        RowBox[{"5", " ", "I"}]}], ",", 
       RowBox[{"10", "+", 
        RowBox[{"5", " ", "I"}]}], ",", 
       RowBox[{"10", "+", 
        RowBox[{"5", " ", "I"}]}]}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"epsB", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"2", "+", "I"}], ",", 
       RowBox[{"2", "+", "I"}], ",", 
       RowBox[{"2.5", "+", 
        RowBox[{"0.5", " ", "I"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{"2.", " ", "Depolarization", " ", "Integral"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"S", "[", 
      RowBox[{"theta_", ",", "phi_", ",", "host_", ",", "invU_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"host", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "*", 
       RowBox[{
        RowBox[{"invU", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "^", "2"}], "*", 
       RowBox[{
        RowBox[{"Sin", "[", "theta", "]"}], "^", "2"}], "*", 
       RowBox[{
        RowBox[{"Cos", "[", "phi", "]"}], "^", "2"}]}], "+", 
      RowBox[{
       RowBox[{"host", "[", 
        RowBox[{"[", "2", "]"}], "]"}], "*", 
       RowBox[{
        RowBox[{"invU", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "^", "2"}], "*", 
       RowBox[{
        RowBox[{"Sin", "[", "theta", "]"}], "^", "2"}], "*", 
       RowBox[{
        RowBox[{"Sin", "[", "phi", "]"}], "^", "2"}]}], "+", 
      RowBox[{
       RowBox[{"host", "[", 
        RowBox[{"[", "3", "]"}], "]"}], "*", 
       RowBox[{
        RowBox[{"invU", "[", 
         RowBox[{"[", "3", "]"}], "]"}], "^", "2"}], "*", 
       RowBox[{
        RowBox[{"Cos", "[", "theta", "]"}], "^", "2"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"getD", "[", 
      RowBox[{"host_", ",", "Uparam_", ",", "type_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"invU", ",", "dx", ",", "dy", ",", "dz"}], "}"}], ",", 
       RowBox[{
        RowBox[{"invU", "=", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"type", "==", "\"\<a\>\""}], ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", "1", ",", 
             RowBox[{"1", "/", "Uparam"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"1", "/", "Uparam"}], ",", "1", ",", "1"}], "}"}]}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"dx", "=", 
         RowBox[{
          RowBox[{"NIntegrate", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"invU", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "^", "2"}], "*", 
               RowBox[{
                RowBox[{"Sin", "[", "theta", "]"}], "^", "3"}], "*", 
               RowBox[{
                RowBox[{"Cos", "[", "phi", "]"}], "^", "2"}]}], ")"}], "/", 
             RowBox[{"S", "[", 
              RowBox[{"theta", ",", "phi", ",", "host", ",", "invU"}], 
              "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"theta", ",", "0", ",", "Pi"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"phi", ",", "0", ",", 
              RowBox[{"2", " ", "Pi"}]}], "}"}]}], "]"}], "/", 
          RowBox[{"(", 
           RowBox[{"4", " ", "Pi"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"dy", "=", 
         RowBox[{
          RowBox[{"NIntegrate", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"invU", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], "^", "2"}], "*", 
               RowBox[{
                RowBox[{"Sin", "[", "theta", "]"}], "^", "3"}], "*", 
               RowBox[{
                RowBox[{"Sin", "[", "phi", "]"}], "^", "2"}]}], ")"}], "/", 
             RowBox[{"S", "[", 
              RowBox[{"theta", ",", "phi", ",", "host", ",", "invU"}], 
              "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"theta", ",", "0", ",", "Pi"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"phi", ",", "0", ",", 
              RowBox[{"2", " ", "Pi"}]}], "}"}]}], "]"}], "/", 
          RowBox[{"(", 
           RowBox[{"4", " ", "Pi"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"dz", "=", 
         RowBox[{
          RowBox[{"NIntegrate", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"invU", "[", 
                 RowBox[{"[", "3", "]"}], "]"}], "^", "2"}], "*", 
               RowBox[{"Sin", "[", "theta", "]"}], "*", 
               RowBox[{
                RowBox[{"Cos", "[", "theta", "]"}], "^", "2"}]}], ")"}], "/", 
             RowBox[{"S", "[", 
              RowBox[{"theta", ",", "phi", ",", "host", ",", "invU"}], 
              "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"theta", ",", "0", ",", "Pi"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"phi", ",", "0", ",", 
              RowBox[{"2", " ", "Pi"}]}], "}"}]}], "]"}], "/", 
          RowBox[{"(", 
           RowBox[{"4", " ", "Pi"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"dx", ",", "dy", ",", "dz"}], "}"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"3.", " ", "Bruggeman", " ", "Solver"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"solveBruggeman", "[", 
      RowBox[{"Uval_", ",", "faVal_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "epsOld", ",", "epsNew", ",", "delta", ",", "n", ",", "Da", ",", "Db",
          ",", "Ta", ",", "Tb", ",", "fa", ",", "fb"}], "}"}], ",", 
       RowBox[{
        RowBox[{"fa", "=", "faVal"}], ";", "\[IndentingNewLine]", 
        RowBox[{"fb", "=", 
         RowBox[{"1", "-", "fa"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"The", " ", "crucial", " ", 
           RowBox[{"fix", ":", 
            RowBox[{
            "ensuring", " ", "epsOld", " ", "initializes", " ", "as", " ", 
             "a", " ", "vector"}]}]}], ",", 
          RowBox[{"not", " ", "a", " ", "matrix"}]}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"epsOld", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"fa", "*", 
             RowBox[{"epsA", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], "+", 
            RowBox[{"fb", "*", 
             RowBox[{"epsB", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "3"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"delta", "=", "1.0"}], ";", "\[IndentingNewLine]", 
        RowBox[{"n", "=", "0"}], ";", "\[IndentingNewLine]", 
        RowBox[{"While", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"delta", ">", 
            RowBox[{"10", "^", 
             RowBox[{"-", "6"}]}]}], "&&", 
           RowBox[{"n", "<", "100"}]}], ",", 
          RowBox[{
           RowBox[{"n", "++"}], ";", "\[IndentingNewLine]", 
           RowBox[{"Da", "=", 
            RowBox[{"getD", "[", 
             RowBox[{"epsOld", ",", "Uval", ",", "\"\<a\>\""}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"Db", "=", 
            RowBox[{"getD", "[", 
             RowBox[{"epsOld", ",", "Uval", ",", "\"\<b\>\""}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"Ta", "=", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"1", "/", 
               RowBox[{"(", 
                RowBox[{"1", "+", 
                 RowBox[{
                  RowBox[{"Da", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], "*", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"epsA", "[", 
