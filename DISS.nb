Cell[CellGroupData[{
Cell["Chapter 2: Kramer\[CloseCurlyQuote]s Kronig", "Section",
 CellChangeTimes->{{3.9818790908479176`*^9, 3.981879111887144*^9}, {
  3.981879485455591*^9, 
