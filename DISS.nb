Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Parameters"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"epsA", "=", 
     RowBox[{"(", 
      RowBox[{"10", "+", 
       RowBox[{"5", " ", "I"}]}], ")"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"epsB", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"2", "+", "I"}], ",", 
       RowBox[{"2", "+", "I"}], ",", 
       RowBox[{"2.5", "+", 
        RowBox[{"0.5", " ", "I"}]}]}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"fa", "=", "0.5"}], ";", 
    RowBox[{"fb", "=", 
     RowBox[{"1", "-", "fa"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"2.", " ", "Depolarization", " ", "Integral"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Host", " ", "is", " ", "a", " ", "list", " ", 
     RowBox[{"{", 
      RowBox[{"ex", ",", "ey", ",", "ez"}], "}"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"S", "[", 
      RowBox[{"theta_", ",", "phi_", ",", "host_", ",", "invU_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"host", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "*", 
       RowBox[{
        RowBox[{"invU", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "^", "2"}], "*", 
       RowBox[{
        RowBox[{"Sin", "[", "theta", "]"}], "^", "2"}], "*", 
       RowBox[{
        RowBox[{"Cos", "[", "phi", "]"}], "^", "2"}]}], "+", 
      RowBox[{
       RowBox[{"host", "[", 
        RowBox[{"[", "2", "]"}], "]"}], "*", 
       RowBox[{
        RowBox[{"invU", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "^", "2"}], "*", 
       RowBox[{
        RowBox[{"Sin", "[", "theta", "]"}], "^", "2"}], "*", 
       RowBox[{
        RowBox[{"Sin", "[", "phi", "]"}], "^", "2"}]}], "+", 
      RowBox[{
       RowBox[{"host", "[", 
        RowBox[{"[", "3", "]"}], "]"}], "*", 
       RowBox[{
        RowBox[{"invU", "[", 
         RowBox[{"[", "3", "]"}], "]"}], "^", "2"}], "*", 
       RowBox[{
        RowBox[{"Cos", "[", "theta", "]"}], "^", "2"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Function", " ", "to", " ", "compute", " ", "the", " ", "triad", " ", 
     "of", " ", "D", " ", "values", " ", "for", " ", "a", " ", "given", " ", 
     "shape", " ", "and", " ", "host"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"getD", "[", 
     RowBox[{"host_", ",", "Uparam_", ",", "type_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"invU", ",", "dx", ",", "dy", ",", "dz"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
         RowBox[{"Material", "'"}], 
         RowBox[{"a", "'"}], " ", "is", " ", "diag", 
         RowBox[{"(", 
          RowBox[{"1", ",", "1", ",", "U"}], ")"}]}], ",", " ", 
        RowBox[{
         RowBox[{"Material", "'"}], 
         RowBox[{"b", "'"}], " ", "is", " ", "diag", 
         RowBox[{"(", 
          RowBox[{"U", ",", "1", ",", "1"}], ")"}]}]}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"invU", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"type", "==", "\"\<a\>\""}], ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", "1", ",", 
            RowBox[{"1", "/", "Uparam"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"1", "/", "Uparam"}], ",", "1", ",", "1"}], "}"}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"dx", "=", 
        RowBox[{
         RowBox[{"NIntegrate", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"invU", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "^", "2"}], " ", 
              RowBox[{
               RowBox[{"Sin", "[", "theta", "]"}], "^", "3"}], " ", 
              RowBox[{
               RowBox[{"Cos", "[", "phi", "]"}], "^", "2"}]}], ")"}], "/", 
            RowBox[{"S", "[", 
             RowBox[{"theta", ",", "phi", ",", "host", ",", "invU"}], "]"}]}],
            ",", 
           RowBox[{"{", 
            RowBox[{"theta", ",", "0", ",", "Pi"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"phi", ",", "0", ",", 
             RowBox[{"2", " ", "Pi"}]}], "}"}]}], "]"}], "/", 
         RowBox[{"(", 
          RowBox[{"4", " ", "Pi"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"dy", "=", 
        RowBox[{
         RowBox[{"NIntegrate", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"invU", "[", 
                RowBox[{"[", "2", "]"}], "]"}], "^", "2"}], " ", 
              RowBox[{
               RowBox[{"Sin", "[", "theta", "]"}], "^", "3"}], " ", 
              RowBox[{
               RowBox[{"Sin", "[", "phi", "]"}], "^", "2"}]}], ")"}], "/", 
            RowBox[{"S", "[", 
             RowBox[{"theta", ",", "phi", ",", "host", ",", "invU"}], "]"}]}],
            ",", 
           RowBox[{"{", 
            RowBox[{"theta", ",", "0", ",", "Pi"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"phi", ",", "0", ",", 
             RowBox[{"2", " ", "Pi"}]}], "}"}]}], "]"}], "/", 
         RowBox[{"(", 
          RowBox[{"4", " ", "Pi"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"dz", "=", 
        RowBox[{
         RowBox[{"NIntegrate", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"invU", "[", 
                RowBox[{"[", "3", "]"}], "]"}], "^", "2"}], " ", 
              RowBox[{"Sin", "[", "theta", "]"}], " ", 
              RowBox[{
               RowBox[{"Cos", "[", "theta", "]"}], "^", "2"}]}], ")"}], "/", 
            RowBox[{"S", "[", 
             RowBox[{"theta", ",", "phi", ",", "host", ",", "invU"}], "]"}]}],
            ",", 
           RowBox[{"{", 
            RowBox[{"theta", ",", "0", ",", "Pi"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"phi", ",", "0", ",", 
             RowBox[{"2", " ", "Pi"}]}], "}"}]}], "]"}], "/", 
         RowBox[{"(", 
          RowBox[{"4", " ", "Pi"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"dx", ",", "dy", ",", "dz"}], "}"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"3.", " ", "Jacobi", " ", "Iteration"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"runJacobi", "[", "Uval_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "epsBr", ",", "history", ",", "n", ",", "Da", ",", "Db", ",", "Ta", ",",
         "Tb"}], "}"}], ",", 
      RowBox[{
       RowBox[{"epsBr", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"fa", "*", 
            RowBox[{"(", 
             RowBox[{"10", "+", 
              RowBox[{"5", " ", "I"}]}], ")"}]}], "+", 
           RowBox[{"fb", "*", 
            RowBox[{"(", 
             RowBox[{"2", "+", "I"}], ")"}]}]}], ",", 
          RowBox[{
           RowBox[{"fa", "*", 
            RowBox[{"(", 
             RowBox[{"10", "+", 
              RowBox[{"5", " ", "I"}]}], ")"}]}], "+", 
           RowBox[{"fb", "*", 
            RowBox[{"(", 
             RowBox[{"2", "+", "I"}], ")"}]}]}], ",", 
          RowBox[{
           RowBox[{"fa", "*", 
            RowBox[{"(", 
             RowBox[{"10", "+", 
              RowBox[{"5", " ", "I"}]}], ")"}]}], "+", 
           RowBox[{"fb", "*", 
            RowBox[{"(", 
             RowBox[{"2.5", "+", 
              RowBox[{"0.5", " ", "I"}]}], ")"}]}]}]}], "}"}]}], ";", 
       RowBox[{"(*", 
        RowBox[{"Initial", " ", "Value", " ", 
         RowBox[{"eps", "[", "0", "]"}]}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"history", "=", 
        RowBox[{"{", "epsBr", "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Step", " ", 
          RowBox[{"A", ":", " ", 
           RowBox[{
           "Recalculate", " ", "D", " ", "for", " ", "both", " ", "materials",
             " ", "based", " ", "on", " ", "current", " ", "epsBr"}]}]}], 
         "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Da", "=", 
           RowBox[{"getD", "[", 
            RowBox[{"epsBr", ",", "Uval", ",", "\"\<a\>\""}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Db", "=", 
           RowBox[{"getD", "[", 
            RowBox[{"epsBr", ",", "Uval", ",", "\"\<b\>\""}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Step", " ", 
            RowBox[{"B", ":", " ", 
             RowBox[{"Calculate", " ", "T", " ", "factors", " ", 
              RowBox[{"(", 
               RowBox[{
               "i", "*", "w", "*", "eps0", " ", "cancels", " ", "out"}], 
               ")"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
          RowBox[{"Ta", "=", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"1", "/", 
              RowBox[{"(", 
               RowBox[{"1", "+", 
                RowBox[{
                 RowBox[{"Da", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], "*", 
                 RowBox[{"(", 
                  RowBox[{"epsA", "-", 
                   RowBox[{"epsBr", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}], ")"}]}]}], ")"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "3"}], "}"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Tb", "=", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"1", "/", 
              RowBox[{"(", 
               RowBox[{"1", "+", 
                RowBox[{
                 RowBox[{"Db", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], "*", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"epsB", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "-", 
                   RowBox[{"epsBr", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}], ")"}]}]}], ")"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "3"}], "}"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Step", " ", 
            RowBox[{"C", ":", 
             RowBox[{
             "Update", " ", "epsBr", " ", "using", " ", "the", " ", "S", " ", 
              "operator"}]}]}], "*)"}], "\[IndentingNewLine]", 
          RowBox[{"epsBr", "=", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"fa", "*", "epsA", "*", 
                 RowBox[{"Ta", "[", 
                  RowBox[{"[", "i", "]"}], "]"}]}], "+", 
                RowBox[{"fb", "*", 
                 RowBox[{"epsB", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], "*", 
                 RowBox[{"Tb", "[", 
                  RowBox[{"[", "i", "]"}], "]"}]}]}], ")"}], "/", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"fa", "*", 
                 RowBox[{"Ta", "[", 
                  RowBox[{"[", "i", "]"}], "]"}]}], "+", 
                RowBox[{"fb", "*", 
                 RowBox[{"Tb", "[", 
                  RowBox[{"[", "i", "]"}], "]"}]}]}], ")"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "3"}], "}"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"history", ",", "epsBr"}], "]"}], ";"}], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", "1", ",", "12"}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", "history"}]}], "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "RUNNING", " ", "AND", " ", "PLOTTING"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Set", " ", "the", " ", "specific", " ", "U"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Uval", "=", "5"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Execute", " ", "the", " ", "loop", " ", "we", " ", "defined", " ", 
     "earlier"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"results", "=", 
     RowBox[{"runJacobi", "[", "Uval", "]"}]}], ";"}]}]}]], "Input",
