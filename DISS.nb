Cell[CellGroupData[{

Cell["Chapter 3: Voigt Conditions", "Section",
 CellChangeTimes->{{3.981879240189705*^9, 
  3.9818792728828583`*^9}},ExpressionUUID->"6fca82b1-db78-3248-a174-\
04fd2ad3afce"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "the", " ", "constant", " ", "permittivity", " ", 
    "matrix"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"eBiax", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"3.093", "+", 
          RowBox[{"0.922", "*", "I"}]}], ",", 
         RowBox[{
          RowBox[{"-", "0.487"}], "-", 
          RowBox[{"0.98", "*", "I"}]}], ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "0.487"}], "-", 
          RowBox[{"0.98", "*", "I"}]}], ",", 
         RowBox[{"3.501", "+", 
          RowBox[{"0.855", "*", "I"}]}], ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", 
         RowBox[{"2.314", "+", 
          RowBox[{"0.720", "*", "I"}]}]}], "}"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Define", " ", "the", " ", "main", " ", "function"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eAniso", "[", 
     RowBox[{
      RowBox[{"alpha_", "?", "NumericQ"}], ",", 
      RowBox[{"beta_", "?", "NumericQ"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "aRad", ",", "bRad", ",", "ry", ",", "rz", ",", "rzT", ",", "ryT"}], 
       "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"aRad", "=", 
        RowBox[{"alpha", "*", "Degree"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"bRad", "=", 
        RowBox[{"beta", "*", "Degree"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Define", " ", "R", " ", "matrices"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"ry", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Cos", "[", "bRad", "]"}], ",", "0", ",", 
            RowBox[{"-", 
             RowBox[{"Sin", "[", "bRad", "]"}]}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "1", ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Sin", "[", "bRad", "]"}], ",", "0", ",", 
            RowBox[{"Cos", "[", "bRad", "]"}]}], "}"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rz", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Cos", "[", "aRad", "]"}], ",", 
            RowBox[{"Sin", "[", "aRad", "]"}], ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"Sin", "[", "aRad", "]"}]}], ",", 
            RowBox[{"Cos", "[", "aRad", "]"}], ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"defining", " ", "transposes"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"rzT", "=", 
        RowBox[{"Transpose", "[", "rz", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ryT", "=", 
        RowBox[{"Transpose", "[", "ry", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"matrix", " ", "multiplication"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"ry", ".", "rz", ".", "eBiax", ".", "rzT", ".", "ryT"}]}]}], 
     "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Define", " ", "the", " ", "Voigt", " ", "Function"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"voigtFunction", "[", 
     RowBox[{
      RowBox[{"alpha_", "?", "NumericQ"}], ",", 
      RowBox[{"beta_", "?", "NumericQ"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "e", ",", "e11", ",", "e12", ",", "e13", ",", "e21", ",", "e22", ",", 
        "e23", ",", "e31", ",", "e32", ",", "e33", ",", "d11", ",", "d12", ",",
         "d21", ",", "d22", ",", "voigtEq"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", "shorthand", " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"e", "=", 
        RowBox[{"eAniso", "[", 
         RowBox[{"alpha", ",", "beta"}], "]"}]}], ";", " ", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Extract", " ", "all", " ", "elements"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"e11", "=", 
        RowBox[{"e", "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", 
       RowBox[{"e12", "=", 
        RowBox[{"e", "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "2"}], "]"}], "]"}]}], ";", 
       RowBox[{"e13", "=", 
        RowBox[{"e", "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "3"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"e21", "=", 
        RowBox[{"e", "[", 
         RowBox[{"[", 
          RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ";", 
       RowBox[{"e22", "=", 
        RowBox[{"e", "[", 
         RowBox[{"[", 
          RowBox[{"2", ",", "2"}], "]"}], "]"}]}], ";", 
       RowBox[{"e23", "=", 
        RowBox[{"e", "[", 
         RowBox[{"[", 
          RowBox[{"2", ",", "3"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"e31", "=", 
        RowBox[{"e", "[", 
         RowBox[{"[", 
          RowBox[{"3", ",", "1"}], "]"}], "]"}]}], ";", 
       RowBox[{"e32", "=", 
        RowBox[{"e", "[", 
         RowBox[{"[", 
          RowBox[{"3", ",", "2"}], "]"}], "]"}]}], ";", 
       RowBox[{"e33", "=", 
        RowBox[{"e", "[", 
         RowBox[{"[", 
          RowBox[{"3", ",", "3"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"build", " ", "deltas"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"d11", "=", 
        RowBox[{
         RowBox[{"e11", "*", "e33"}], "-", 
         RowBox[{"e13", "*", "e31"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"d12", "=", 
        RowBox[{
         RowBox[{"e12", "*", "e33"}], "-", 
         RowBox[{"e13", "*", "e32"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"d21", "=", 
        RowBox[{
         RowBox[{"e21", "*", "e33"}], "-", 
         RowBox[{"e23", "*", "e31"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"d22", "=", 
        RowBox[{
         RowBox[{"e22", "*", "e33"}], "-", 
         RowBox[{"e23", "*", "e32"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"define", " ", "condition"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"voigtEq", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"d11", "-", "d22"}], ")"}], "^", "2"}], "+", 
         RowBox[{"4", "*", "d12", "*", "d21"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Return", " ", "the", " ", "magnitude", " ", "squared"}], 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Abs", "[", "voigtEq", "]"}], "^", "2"}]}]}], 
     "\[IndentingNewLine]", "]"}], " "}]}]}]], "Input",
 CellChangeTimes->{{3.981879280521469*^9, 3.9818793848956127`*^9}, {
  3.9818794936755276`*^9, 3.9818795251972923`*^9}, {3.981880391894745*^9, 
  3.981880405305088*^9}, {3.9818887158658676`*^9, 3.98188871768754*^9}, {
  3.9823988033367558`*^9, 
  3.982398808196863*^9}},ExpressionUUID->"cd737964-ebd0-d042-9249-\
8bbb3b29709a"],

