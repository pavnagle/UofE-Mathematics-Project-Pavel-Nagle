          RowBox[{"3", ",", "1"}], "]"}], "]"}]}], ";", 
       RowBox[{"e32", "=", 
        RowBox[{"e", "[", 
         RowBox[{"[", 
          RowBox[{"3", ",", "2"}], "]"}], "]"}]}], ";", 
       RowBox[{"e33", "=", 
        RowBox[{"e", "[", 
         RowBox[{"[", 
          RowBox[{"3", ",", "3"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"build", " ", "deltas"}], "*)"}], 
       RowBox[{"d11", "=", 
        RowBox[{
         RowBox[{"e11", "*", "e33"}], "-", 
         RowBox[{"e13", "*", "e31"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"d12", "=", 
        RowBox[{
         RowBox[{"e12", "*", "e33"}], "-", 
         RowBox[{"e13", "*", "e32"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"d21", "=", 
        RowBox[{
         RowBox[{"e21", "*", "e33"}], "-", 
         RowBox[{"e23", "*", "e31"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"d22", "=", 
        RowBox[{
         RowBox[{"e22", "*", "e33"}], "-", 
         RowBox[{"e23", "*", "e32"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"define", " ", "condition"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"voigtEq", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"d11", "-", "d22"}], ")"}], "^", "2"}], "+", 
         RowBox[{"4", "*", "d12", "*", "d21"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Return", " ", "the", " ", "magnitude", " ", "squared"}], 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Abs", "[", "voigtEq", "]"}], "^", "2"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
  "Print", "[", "\"\<Plotting Macroscopic Voigt Landscape with Log scaling...\
\>\"", "]"}], ";"}], "\n", 
 RowBox[{"ContourPlot", "[", 
  RowBox[{
   RowBox[{"Log", "[", 
    RowBox[{"voigtFunction", "[", 
     RowBox[{"a", ",", "b"}], "]"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"a", ",", "0", ",", "180"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"b", ",", "90", ",", "180"}], "}"}], ",", 
   RowBox[{"PlotLegends", "->", "Automatic"}], ",", 
   RowBox[{"Contours", "->", "50"}], ",", 
   RowBox[{"PlotPoints", "->", "40"}], ",", 
   RowBox[{"MaxRecursion", "->", "2"}], ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Alpha] (degrees)\>\"", ",", "\"\<\[Beta] (degrees)\>\""}],
      "}"}]}], ",", 
   RowBox[{"PlotLabel", "->", "None"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9818801030677967`*^9, 3.9818801030677967`*^9}, {
  3.9818803245456696`*^9, 3.981880324795471*^9}, {3.981880479715788*^9, 
