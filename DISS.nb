Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Define", " ", "constants"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"a", "=", "10"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Omega", "=", "1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"b", "=", "2.5"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Define", " ", "Imaginary", " ", "part", " ", "function"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"imChi", "[", "w_", "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"a", "*", "w", "*", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"w", "^", "2"}], "-", 
           RowBox[{"Omega", "^", "2"}]}], ")"}], "^", "2"}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"w", "^", "8"}], "+", "b"}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "real", " ", "part", " ", "by", " ", "numerical", " ", 
     "integration", " ", "of", " ", "imaginary", " ", "part"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Added", " ", "a", " ", "small", " ", "MaxRecursion", " ", "boost", " ", 
     "for", " ", "smoother", " ", "results", " ", "near", " ", "peaks"}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"reChi", "[", 
     RowBox[{"w_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"2", "/", "Pi"}], ")"}], "*", 
     RowBox[{"NIntegrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"s", "*", 
          RowBox[{"imChi", "[", "s", "]"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"s", "^", "2"}], "-", 
          RowBox[{"w", "^", "2"}]}], ")"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"s", ",", "0", ",", "w", ",", "Infinity"}], "}"}], ",", 
       RowBox[{"Method", "->", "\"\<PrincipalValue\>\""}], ",", 
       RowBox[{"MaxRecursion", "->", "20"}]}], "]"}]}]}]}]}]], "Input",
 CellChangeTimes->{
  3.9818794345913773`*^9, {3.9818794654654617`*^9, 3.981879479765476*^9}, {
   3.981887755518368*^9, 3.981887755986809*^9}, {3.9818883223229656`*^9, 
   3.9818883273876762`*^9}, {3.981888371408844*^9, 3.9818883769280453`*^9}, 
   3.9823985121685944`*^9},ExpressionUUID->"94229d96-6f1a-9e4c-9888-\
1fd889cede1d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Plot", " ", "real", " ", "and", " ", "imaginary", " ", "parts", " ", 
    "together"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"imChi", "[", "w", "]"}], ",", 
      RowBox[{"reChi", "[", "w", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"w", ",", "0", ",", "10"}], "}"}], ",", 
