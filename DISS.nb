Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Extract", " ", "matrix", " ", "components"}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"hx", ",", "hy", ",", "hz"}], "}"}], "=", 
     RowBox[{"Transpose", "[", "results", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "1.", " ", "Calculate", " ", "convergence", " ", "iteration", " ", 
     "safely"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"stepErrors", "=", 
     RowBox[{"Norm", "/@", 
      RowBox[{"Differences", "[", "results", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"convIter", "=", 
     RowBox[{
      RowBox[{"FirstPosition", "[", 
       RowBox[{"stepErrors", ",", 
        RowBox[{"e_", "/;", 
         RowBox[{"e", "<", 
          RowBox[{"10", "^", 
           RowBox[{"-", "6"}]}]}]}], ",", 
        RowBox[{"{", "None", "}"}], ",", 
        RowBox[{"{", "1", "}"}]}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"3.", " ", "Define", " ", "Labels"}], "&"}], " ", "Options"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"myLabels", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{"\"\<x\>\"", ",", "15", ",", "Bold"}], "]"}], ",", 
       RowBox[{"Style", "[", 
        RowBox[{"\"\<y\>\"", ",", "15", ",", "Bold"}], "]"}], ",", 
       RowBox[{"Style", "[", 
        RowBox[{"\"\<z\>\"", ",", "15", ",", "Bold"}], "]"}]}], "}"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"commonOptions", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Frame", "->", "True"}], ",", 
       RowBox[{"PlotStyle", "->", "layeredStyles"}], ",", 
       RowBox[{"Mesh", "->", "All"}], ",", 
       RowBox[{"LabelStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{"Black", ",", "14"}], "]"}]}], ",", 
       RowBox[{"ImageSize", "->", "500"}], ",", 
       RowBox[{"GridLines", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", "convIter", "}"}], ",", "None"}], "}"}]}], ",", 
       RowBox[{"GridLinesStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{
          RowBox[{"Darker", "[", "Gray", "]"}], ",", "Dashed", ",", 
          RowBox[{"AbsoluteThickness", "[", "1.5", "]"}]}], "]"}]}]}], 
      "}"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Plot", " ", "and", " ", "Export"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"realPlot", "=", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Re", "[", "hx", "]"}], ",", 
         RowBox[{"Re", "[", "hy", "]"}], ",", 
         RowBox[{"Re", "[", "hz", "]"}]}], "}"}], ",", 
       RowBox[{"PlotLabel", "->", "None"}], ",", 
       RowBox[{"PlotLabels", "->", 
        RowBox[{"Placed", "[", 
         RowBox[{"myLabels", ",", "After"}], "]"}]}], ",", 
       RowBox[{"Evaluate", "@", "commonOptions"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"imagPlot", "=", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Im", "[", "hx", "]"}], ",", 
         RowBox[{"Im", "[", "hy", "]"}], ",", 
         RowBox[{"Im", "[", "hz", "]"}]}], "}"}], ",", 
       RowBox[{"PlotLabel", "->", "None"}], ",", 
       RowBox[{"PlotLabels", "->", 
        RowBox[{"Placed", "[", 
         RowBox[{"myLabels", ",", "After"}], "]"}]}], ",", 
       RowBox[{"Evaluate", "@", "commonOptions"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "realPlot", "\[IndentingNewLine]",
    "imagPlot"}]}]], "Input",
 CellChangeTimes->{{3.9818804602291183`*^9, 3.9818804723259735`*^9}, {
