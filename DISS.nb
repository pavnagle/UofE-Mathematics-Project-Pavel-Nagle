   RowBox[{"frac", "*", 
    RowBox[{"epsL", ".", 
     RowBox[{"Inverse", "[", 
      RowBox[{
       RowBox[{"IdentityMatrix", "[", "3", "]"}], "+", 
       RowBox[{"DL", ".", 
        RowBox[{"(", 
         RowBox[{"epsL", "-", "epsBr"}], ")"}]}]}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"SOperator", "[", 
    RowBox[{"epsBr_", ",", "psi_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "Da", ",", "Db", ",", "termA", ",", "termB", ",", "brackets", ",", 
       "result"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Computing D for psi = \>\"", ",", "psi"}], "]"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Calculate", " ", "depolarization", " ", "dyadics", " ", "for", " ", 
        "current", " ", "bruggeman"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Da", "=", 
       RowBox[{"DGen", "[", 
        RowBox[{"invUa", ",", "epsBr"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", "\"\<Da computed\>\"", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Db", "=", 
       RowBox[{"DGen", "[", 
        RowBox[{
         RowBox[{"invUb", "[", "psi", "]"}], ",", "epsBr"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", "\"\<Db computed\>\"", "]"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Calculate", " ", "individual", " ", "material", " ", "terms"}], " ", 
       "*)"}], "\[IndentingNewLine]", 
      RowBox[{"termA", "=", 
       RowBox[{"CalcTerm", "[", 
        RowBox[{"fa", ",", "epsA", ",", "Da", ",", "epsBr"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"termB", "=", 
       RowBox[{"CalcTerm", "[", 
        RowBox[{"fb", ",", "epsB", ",", "Db", ",", "epsBr"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Calculate", " ", "the", " ", "inverse", " ", "bracket", " ", "term"}],
        " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"brackets", "=", 
       RowBox[{"Inverse", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"fa", "*", 
          RowBox[{"Inverse", "[", 
           RowBox[{
            RowBox[{"IdentityMatrix", "[", "3", "]"}], "+", 
            RowBox[{"Da", ".", 
             RowBox[{"(", 
              RowBox[{"epsA", "-", "epsBr"}], ")"}]}]}], "]"}]}], "+", 
         "\[IndentingNewLine]", 
         RowBox[{"fb", "*", 
          RowBox[{"Inverse", "[", 
           RowBox[{
            RowBox[{"IdentityMatrix", "[", "3", "]"}], "+", 
            RowBox[{"Db", ".", 
             RowBox[{"(", 
              RowBox[{"epsB", "-", "epsBr"}], ")"}]}]}], "]"}]}]}], 
        "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"Final", " ", "Matrix", " ", "Multiplication"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"result", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"termA", "+", "termB"}], ")"}], ".", "brackets"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "result", "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"SolveHCM", "[", "psi_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "epsCurrent", ",", "epsNext", ",", "err", ",", "iter", ",", "maxIter"}],
       "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<\\n=== Starting HCM solve for psi = \>\"", ",", "psi", 
        ",", "\"\< ===\>\""}], "]"}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"Initial", " ", "Guess"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"epsCurrent", "=", 
       RowBox[{
        RowBox[{"fa", "*", "epsA"}], "+", 
        RowBox[{"fb", "*", "epsB"}]}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"Iteration", " ", "Loop"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"maxIter", "=", "15"}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"iter", "=", "1"}], ",", 
        RowBox[{"iter", "<=", "maxIter"}], ",", 
        RowBox[{"iter", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"epsNext", "=", 
          RowBox[{"SOperator", "[", 
           RowBox[{"epsCurrent", ",", "psi"}], "]"}]}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{"Check", " ", "Convergence"}], " ", "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{"err", "=", 
          RowBox[{"Norm", "[", 
           RowBox[{
            RowBox[{"epsNext", "-", "epsCurrent"}], 
            ",", "\"\<Frobenius\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<  Error: \>\"", ",", "err"}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"epsCurrent", "=", "epsNext"}], ";", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{"Break", " ", "if", " ", "converged"}], " ", "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"err", "<", 
            SuperscriptBox["10", 
             RowBox[{"-", "6"}]]}], ",", 
           RowBox[{
            RowBox[{"Print", "[", "\"\<  Converged!\>\"", "]"}], ";", 
            RowBox[{"Break", "[", "]"}]}]}], "]"}], ";"}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "epsCurrent", "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}], "\n", 
 RowBox[{
