Cell[CellGroupData[{

Cell["Real and positive components of the permittivity dyadic", "Subsection",
 CellChangeTimes->{{3.9818842142838707`*^9, 
  3.981884255692793*^9}},ExpressionUUID->"56b0ffdb-8739-de4a-9dc4-\
0644e288cfb4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Define", " ", "Permittivity", " ", "Parameters"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"epsX", "=", "2"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"epsY", "=", "4"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"epsZ", "=", "5"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "2.", " ", "Define", " ", "Denominator", " ", "Function", " ", "S"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"S", "[", 
      RowBox[{"theta_", ",", "phi_", ",", "gamma_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"gamma", "*", 
       RowBox[{
        RowBox[{"Sin", "[", "theta", "]"}], "^", "2"}], "*", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"epsX", "*", 
          RowBox[{
           RowBox[{"Cos", "[", "phi", "]"}], "^", "2"}]}], "+", 
         RowBox[{"epsY", "*", 
          RowBox[{
           RowBox[{"Sin", "[", "phi", "]"}], "^", "2"}]}]}], ")"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"epsZ", "/", 
         RowBox[{"gamma", "^", "2"}]}], ")"}], "*", 
       RowBox[{
        RowBox[{"Cos", "[", "theta", "]"}], "^", "2"}]}]}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Define", " ", "the", " ", "Integrands", " ", "derived", " ", 
     "in", " ", 
     TemplateBox[<|
