 RowBox[{
  RowBox[{
   RowBox[{
   "Print", "[", "\"\<\\n=== Generating Chapter 6 Matrix at \[Psi] = \[Pi]/4 \
===\>\"", "]"}], ";"}], "\n", 
  RowBox[{"(*", 
   RowBox[{
   "We", " ", "divide", " ", "by", " ", "eps0", " ", "to", " ", "keep", " ", 
