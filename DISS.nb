 RowBox[{
  RowBox[{"Uval", "=", "5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fa", "=", "0.5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fb", "=", "0.5"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"epsA", "=", 
   RowBox[{"eps0", "*", 
    RowBox[{"(", 
     RowBox[{"10", "+", 
      RowBox[{"5", "I"}]}], ")"}], "*", 
    RowBox[{"IdentityMatrix", "[", "3", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"epsB", "=", 
   RowBox[{"eps0", "*", 
    RowBox[{"DiagonalMatrix", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"2", "+", "I"}], ",", 
       RowBox[{"2", "+", "I"}], ",", 
       RowBox[{"2.5", "+", 
        RowBox[{"0.5", "I"}]}]}], "}"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Rmat", "[", "psi_", "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", "psi", "]"}], ",", 
