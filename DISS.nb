              RowBox[{"{", 
               RowBox[{"i", ",", "3"}], "}"}]}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"delta", "=", 
            RowBox[{"Max", "[", 
             RowBox[{"Abs", "[", 
