Cell[CellGroupData[{

Cell["Minimising for zero determinant", "Subsection",
 CellChangeTimes->{{3.9818844831714935`*^9, 
  3.9818845001735916`*^9}},ExpressionUUID->"fd9c095e-b031-fe4b-a237-\
aa1eb655e1cb"],

Cell[BoxData[{
 RowBox[{"Print", "[", "\"\<Finding minima of voigtFunction[]...\>\"", 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"sol1", "=", 
  RowBox[{"NMinimize", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"voigtFunction", "[", 
       RowBox[{"a", ",", "b"}], "]"}], ",", 
      RowBox[{"(*", 
       RowBox[{"Function", " ", "to", " ", "minimize"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"0", "<", "a", "<", "50"}], ",", 
      RowBox[{"(*", 
       RowBox[{"Split", " ", "the", " ", "alpha", " ", "range"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"90", "<", "b", "<", "180"}]}], "                ", 
     RowBox[{"(*", " ", 
      RowBox[{"beta", " ", "range"}], "*)"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"a", ",", "b"}], "}"}]}], "                      ", 
   RowBox[{"(*", 
    RowBox[{"solution", " ", "pair"}], "*)"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"sol2", "=", 
  RowBox[{"NMinimize", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"voigtFunction", "[", 
       RowBox[{"a", ",", "b"}], "]"}], ",", 
      RowBox[{"(*", 
       RowBox[{"Function", " ", "to", " ", "minimize"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"50", "<", "a", "<", "180"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "second", " ", "half", " ", "of", " ", "the", " ", "alpha", " ", 
        "range"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"90", "<", "b", "<", "180"}]}], "                ", 
     RowBox[{"(*", " ", 
      RowBox[{"beta", " ", "range"}], "*)"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"a", ",", "b"}], "}"}]}], "                      ", 
   RowBox[{"(*", 
    RowBox[{"solution", " ", "pair"}], "*)"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", "\"\<Minima found!\>\"", "]"}]}], "Input",
 CellChangeTimes->{{3.981880542155916*^9, 3.9818805522654133`*^9}, {
  3.981880632895899*^9, 3.981880695407133*^9}, {3.981880726485588*^9, 
